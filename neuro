DATA_DIR = "./dataset_final"
NUM_EPOCHS = 30
SAMPLE_RATE = 30242
N_FFT = 2048 # разрешение по частоте
BATCH_SIZE = 32
DURATION = 3  # Секунды
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")


class BelugaExpertDataset(Dataset):
    def __init__(self, root_dir, augment=True):
        self.root_dir = root_dir
        self.augment = augment
        self.sample_rate = 30242
        self.duration = 3
        self.num_samples = self.sample_rate * self.duration  # Лимит в семплах (90726)

        self.file_list = []
        for class_name in ["noise", "beluga"]:
            p = os.path.join(root_dir, class_name)
            if os.path.exists(p):
                for f in os.listdir(p):
                    if f.endswith(".wav"):
                        self.file_list.append((os.path.join(p, f), 1 if class_name == "beluga" else 0))

        # Линейная спектрограмма
        self.spec_transform = T.Spectrogram(n_fft=2048, hop_length=512)
        self.db_transform = T.AmplitudeToDB()

    def __len__(self):
        return len(self.file_list)

    def __getitem__(self, idx):
        path, label = self.file_list[idx]

        waveform, sr = torchaudio.load(path)

        if waveform.shape[0] > 1:
            waveform = torch.mean(waveform, dim=0, keepdim=True)

        # Фиксация длины
        if waveform.shape[1] > self.num_samples:
            # Если файл длиннее 3 сек — обрезаем
            waveform = waveform[:, :self.num_samples]
        elif waveform.shape[1] < self.num_samples:
            # Если файл короче 3 сек — дополняем нулями
            pad_amount = self.num_samples - waveform.shape[1]
            waveform = F.pad(waveform, (0, pad_amount))

        # Аугментация
        if self.augment:
            # Случайный сдвиг
            shift = random.randint(-self.sample_rate // 2, self.sample_rate // 2)
            waveform = torch.roll(waveform, shift, dims=1)

        # Превращаем в спектрограмму
        spec = self.spec_transform(waveform)
        spec = self.db_transform(spec)

        # Дублируем до 3 каналов для ResNet
        return spec.repeat(3, 1, 1), label


