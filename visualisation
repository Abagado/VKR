# НАСТРОЙКИ 
BELUGA_FILE = "dataset_final/train/beluga/6b2bb6685db6577 (mp3cut.net) (5).wav"  
NOISE_FILE = "dataset_final/train/noise/19.08.2020_1306_суда7.wav"  
SR = 30242  
DURATION = 3  
N_FFT = 2048
HOP_LENGTH = 512


def fix_length(y, target_samples):
    if len(y) > target_samples:
        return y[:target_samples]
    else:
        return np.pad(y, (0, target_samples - len(y)))


def create_augmentation_plot():
    target_samples = SR * DURATION

    y_beluga, _ = librosa.load(BELUGA_FILE, sr=SR)
    y_noise, _ = librosa.load(NOISE_FILE, sr=SR)

    y_beluga = fix_length(y_beluga, target_samples)
    y_noise = fix_length(y_noise, target_samples)

    y_beluga = y_beluga / (np.max(np.abs(y_beluga)) + 1e-8)
    y_noise = y_noise / (np.max(np.abs(y_noise)) + 1e-8)

    y_mixed = (y_beluga * 0.6) + (y_noise * 0.4)
    y_mixed = y_mixed / (np.max(np.abs(y_mixed)) + 1e-8)

    # Расчет спектрограмм
    def get_spec(y):
        D = librosa.stft(y, n_fft=N_FFT, hop_length=HOP_LENGTH)
        return librosa.amplitude_to_db(np.abs(D), ref=np.max)

    s_beluga = get_spec(y_beluga)
    s_noise = get_spec(y_noise)
    s_mixed = get_spec(y_mixed)

    # Визуализация
    fig, ax = plt.subplots(1, 3, figsize=(18, 5))

    # Настройки отображения
    params = {
        'sr': SR,
        'hop_length': HOP_LENGTH,
        'x_axis': 'time',
        'y_axis': 'linear',
        'cmap': 'magma',
        'vmin': -60,
        'vmax': 0
    }

    # График 1: Чистый звук белухи
    img1 = librosa.display.specshow(s_beluga, ax=ax[0], **params)
    ax[0].set_title("А: Исходный сигнал (Белуха)")
    ax[0].set_ylabel("Частота (Гц)")
    ax[0].set_ylim(500, 14000)

    # График 2: Шум
    img2 = librosa.display.specshow(s_noise, ax=ax[1], **params)
    ax[1].set_title("Б: Исходный шум (Обская губа)")
    ax[1].set_ylabel("")  # Убираем лишние подписи по центру
    ax[1].set_ylim(500, 14000)

    # График 3: Смесь
    img3 = librosa.display.specshow(s_mixed, ax=ax[2], **params)
    ax[2].set_title("В: Результат Background Injection")
    ax[2].set_ylabel("")
    ax[2].set_ylim(500, 14000)

    plt.tight_layout()
    plt.savefig("augmentation_demo.png", dpi=300)
    plt.show()


if __name__ == "__main__":
    create_augmentation_plot()

