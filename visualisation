class ExpertVisualizer:
    def __init__(self, model_path):
        self.model = models.resnet18()
        self.model.fc = nn.Linear(self.model.fc.in_features, 2)

        state_dict = torch.load(model_path, map_location=DEVICE, weights_only=True)
        self.model.load_state_dict(state_dict)
        self.model.to(DEVICE).eval()

        self.spec_transform = T.Spectrogram(n_fft=N_FFT, hop_length=HOP_LENGTH)
        self.db_transform = T.AmplitudeToDB(top_db=80)

        # Переменные для Grad-CAM
        self.gradients = None
        self.activations = None
        
        self.model.layer4[-1].register_forward_hook(self._save_activation)
        self.model.layer4[-1].register_full_backward_hook(self._save_gradient)

    def _save_activation(self, m, i, o):
        self.activations = o

    def _save_gradient(self, m, gi, go):
        self.gradients = go[0]

    def process(self, path):
        wave, sr = torchaudio.load(path)
        if wave.shape[0] > 1: wave = torch.mean(wave, dim=0, keepdim=True)
        if sr != SAMPLE_RATE: wave = T.Resample(sr, SAMPLE_RATE)(wave)

        num_samples = SAMPLE_RATE * DURATION
        if wave.shape[1] > num_samples:
            wave = wave[:, :num_samples]
        else:
            wave = F.pad(wave, (0, num_samples - wave.shape[1]))

        spec_raw = self.spec_transform(wave)
        spec_db = self.db_transform(spec_raw)

        input_tensor = spec_db.repeat(3, 1, 1).unsqueeze(0).to(DEVICE)
        input_tensor.requires_grad = True

        out = self.model(input_tensor)
        prob = torch.softmax(out, dim=1)
        idx = torch.argmax(prob).item()

        self.model.zero_grad()
        out[0, idx].backward()

        grads = self.gradients.detach().cpu().numpy()
        acts = self.activations.detach().cpu().numpy()

        weights = np.mean(grads, axis=(2, 3))[0]
        cam = np.zeros(acts.shape[2:], dtype=np.float32)

        for i, w in enumerate(weights):
            cam += w * acts[0, i, :, :]

        cam = np.maximum(cam, 0)
        cam = cv2.resize(cam, (spec_db.shape[2], spec_db.shape[1]))
        if cam.max() > 0: cam /= cam.max()

        s_img = spec_db.numpy()[0]
        vmin = np.percentile(s_img, 40)  # Было 50, сделаем 40
        vmax = np.percentile(s_img, 99.5)

        cam = np.maximum(cam, 0)
        if cam.max() > 0:
            cam = cam / cam.max()

        cam = np.power(cam, 0.7)  

        return s_img, cam, CLASSES[idx], prob[0, idx].item(), vmin, vmax


