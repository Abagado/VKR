def plot_sliding_window_demo():
    # Генерируем тестовый сигнал (6 секунд)
    fs = 1000
    t = np.linspace(0, 6, 6 * fs)

    # Сначала тишина, потом всплеск (белуха), потом снова тишина
    signal = np.random.normal(0, 0.001, len(t))  # фон
    # Добавляем "белуху" в середине
    signal[2000:3500] += 0.1 * np.sin(2 * np.pi * 50 * t[2000:3500])
    # Добавляем "шум" в конце, но тихий
    signal[4500:5500] += 0.003 * np.random.randn(1000)

    fig, ax = plt.subplots(figsize=(12, 6))
    ax.plot(t, signal, color='gray', alpha=0.5, label='Акустический сигнал')

    # Параметры окон (в секундах)
    win_len = 3.0
    step = 1.5
    threshold = 0.005  # RMS Порог

    colors = ['blue', 'green', 'red']
    for i, start in enumerate([0, 1.5, 3]):
        end = start + win_len
        idx = (t >= start) & (t <= end)
        chunk = signal[idx]
        rms = np.sqrt(np.mean(chunk ** 2))

        # Рисуем рамку окна
        rect_y = -0.15 - (i * 0.02)  # Смещение рамок по вертикали для наглядности
        is_passed = rms >= threshold
        color = colors[i] if is_passed else 'black'
        linestyle = '-' if is_passed else '--'

        ax.hlines(rect_y, start, end, colors=color, linestyles=linestyle, lw=3)
        ax.text((start + end) / 2, rect_y - 0.01, f'Окно {i + 1}\nRMS: {rms:.4f}',
                color=color, ha='center', va='top', fontsize=10)

    # Линия порога RMS
    ax.axhline(threshold, color='red', linestyle=':', label='Порог RMS (0.005)')
    ax.axhline(-threshold, color='red', linestyle=':')

    ax.set_title('Визуализация метода скользящего окна и RMS-фильтрации')
    ax.set_xlabel('Время (с)')
    ax.set_ylabel('Амплитуда')
    ax.set_ylim(-0.3, 0.2)
    ax.legend(loc='upper right')
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.savefig('sliding_window_rms.png', dpi=300)
    plt.show()


plot_sliding_window_demo()
